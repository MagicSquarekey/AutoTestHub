# AutoTest Hub 环境变量配置
# 复制此文件为 .env 并填入实际值

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/autotest.db

# 服务器配置
BACKEND_PORT=8000
FRONTEND_PORT=5173
DEBUG=true
SECRET_KEY=your-secret-key-here

# AI 配置（可选）
AI_API_KEY=
AI_API_URL=
AI_MODEL=gpt-4

# 通知配置（可选）
# SMTP 邮件通知
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# 钉钉通知
DINGTALK_WEBHOOK=

# 企业微信通知
WECHAT_WEBHOOK=

# 报告配置
REPORT_DIR=./data/reports
SCREENSHOT_DIR=./data/screenshots

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./data/logs
